# DragonClaw Production Environment
# Copy to .env and fill in your values
# NEVER commit this file to git

# ── LLM Provider ──
DRAGONCLAW_LLM_PROVIDER=deepseek
DRAGONCLAW_LLM_API_KEY=sk-your-key-here
DRAGONCLAW_LLM_MODEL=deepseek-chat

# ── Gateway Security ──
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DRAGONCLAW_GATEWAY_TOKEN=

# ── Binance (optional) ──
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── Connectors (optional) ──
TELEGRAM_BOT_TOKEN=

# ── Logging ──
LOG_LEVEL=info
